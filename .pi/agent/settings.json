{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "showHardwareCursor": false,
  "theme": "catppuccin-mocha",
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-markdown-preview",
    "npm:@juicesharp/rpiv-btw",
    "npm:pi-ask-user",
    "npm:pi-agent-browser-native",
    "npm:pi-mermaid",
    {
      "source": "npm:pi-session-context",
      "extensions": [],
      "skills": [],
      "prompts": [],
      "themes": []
    },
    "npm:pi-web-access",
    "npm:pi-prompt-shelf",
    "npm:context-mode",
    "npm:@latentminds/pi-quotas",
    "npm:@aliou/pi-processes",
    "npm:@zenobius/pi-worktrees",
    "npm:pi-tmux-window-name",
    "npm:pi-workbench",
    {
      "source": "https://github.com/aspiers/pi-status@fix/pi-status-title-renames",
      "extensions": [
        "+src/index.ts"
      ]
    },
    "npm:@vanillagreen/pi-skills-manager",
    {
      "source": "npm:@vanillagreen/pi-tool-renderer",
      "extensions": [],
      "skills": [],
      "prompts": [],
      "themes": []
    },
    "npm:@vanillagreen/pi-session-manager",
    "npm:@vanillagreen/pi-extension-manager",
    "npm:pi-resource-center",
    {
      "source": "npm:@ifi/oh-pi-themes",
      "extensions": [],
      "skills": [],
      "prompts": [],
      "themes": []
    },
    {
      "source": "npm:amp-themes",
      "extensions": [
        "-extensions/amp-editor.ts",
        "-extensions/amp-user-message.ts",
        "-node_modules/pi-tool-display/index.ts"
      ],
      "skills": [
        "-skills/release-amp-themes/SKILL.md",
        "-skills/configure-amp-themes/SKILL.md"
      ]
    },
    "npm:@sherif-fanous/pi-catppuccin",
    "npm:@sherif-fanous/pi-theme-sync",
    "npm:@siesing/pi-shortcuts",
    {
      "source": "npm:pi-recap",
      "extensions": [],
      "skills": [],
      "prompts": [],
      "themes": []
    },
    "npm:@tmustier/pi-session-recap",
    "npm:@brain0pia/pi-extension-times",
    "npm:pi-lens",
    "npm:@lukemelnik/pi-monitor",
    "npm:pi-peek"
  ],
  "hideThinkingBlock": false,
  "powerline": {
    "preset": "ascii",
    "fixedEditor": false
  },
  "enableSkillCommands": true,
  "treeFilterMode": "user-only",
  "piStatus": {
    "separator": " ",
    "components": [
      {
        "id": "spinner",
        "enabled": true
      },
      {
        "id": "pi_symbol",
        "enabled": false
      },
      {
        "id": "session",
        "enabled": true
      },
      {
        "id": "cwd",
        "enabled": false
      },
      {
        "id": "model",
        "enabled": false
      },
      {
        "id": "thinking",
        "enabled": false
      },
      {
        "id": "tokens",
        "enabled": false
      },
      {
        "id": "turn",
        "enabled": false
      },
      {
        "id": "git_branch",
        "enabled": false
      },
      {
        "id": "tools_count",
        "enabled": false
      },
      {
        "id": "current_tool",
        "enabled": false
      }
    ],
    "ghosttySupport": true
  },
  "vstack": {
    "extensionManager": {
      "disabledItems": [
        "package:pi-recap",
        "package:pi-tool-renderer"
      ],
      "config": {
        "@vanillagreen/pi-tool-renderer": {
          "bashOutputMode": "opencode",
          "enabled": true,
          "renderMutationTools": true,
          "pendingStatusAnimation": true
        },
        "@vanillagreen/pi-session-manager": {
          "shortcutKey": "alt+m"
        }
      }
    }
  }
}