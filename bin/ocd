#!/bin/bash
#
# ocd - OpenCode desktop (Tauri) app

OPENCODE_REPO="$HOME/.GIT/3rd-party/opencode"

if [[ ! -d "$OPENCODE_REPO" ]]; then
    echo "error: opencode repo not found at $OPENCODE_REPO" >&2
    exit 1
fi

# Find bun: prefer ~/.bun/bin, then $PATH
if [[ -x "$HOME/.bun/bin/bun" ]]; then
    bun="$HOME/.bun/bin/bun"
elif command -v bun &>/dev/null; then
    bun="$(command -v bun)"
else
    echo "error: bun not found" >&2
    exit 1
fi

cd "$OPENCODE_REPO" || exit 1

"$bun" --cwd=packages/desktop build || exit 1

exec systemd-run --user --scope \
    --unit="opencode-desktop-$$" \
    -p MemoryMax=16G \
    "$bun" --cwd=packages/desktop tauri dev \
    "$@"
